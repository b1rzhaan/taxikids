# ── Django ────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-in-production-super-secret-key
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend,10.0.2.2
DJANGO_SETTINGS_MODULE=kidstransfer.settings

# ── Database (PostgreSQL) ─────────────────────────────────
POSTGRES_DB=kidstransfer
POSTGRES_USER=kidstransfer
POSTGRES_PASSWORD=kidstransfer
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ── Redis (Channels + Celery) ─────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── JWT ───────────────────────────────────────────────────
JWT_ACCESS_LIFETIME_MIN=60
JWT_REFRESH_LIFETIME_DAYS=7

# ── Map provider ──────────────────────────────────────────
# mock | twogis
MAP_PROVIDER=mock
TWOGIS_API_KEY=
TWOGIS_BASE_URL=https://routing.api.2gis.com
TWOGIS_CATALOG_URL=https://catalog.api.2gis.com

# ── Payment provider ──────────────────────────────────────
# mock | kaspi | halyk | stripe
PAYMENT_PROVIDER=mock
PAYMENT_WEBHOOK_SECRET=mock-webhook-secret

# ── Business rules ────────────────────────────────────────
# Доля водителя от стоимости поездки (0.70 = 70%), приложение забирает остаток
DRIVER_REVENUE_SHARE=0.70
DEFAULT_CURRENCY=KZT
